{
  "name": "rbx15-classic-shirt-and-pants-maker",
  "productName": "RBX15 Classic Shirt and Pants Maker",
  "version": "4.0.1",
  "description": "Roblox Classic R15 shirt and pants template maker. Built by ItsjustEste at 626 Labs LLC.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --publish never",
    "lint": "eslint main.js editor.js",
    "test": "node --test \"tests/**/*.test.js\""
  },
  "keywords": [
    "roblox",
    "shirt",
    "editor",
    "r15"
  ],
  "author": "ItsjustEste / 626 Labs LLC",
  "license": "MIT",
  "build": {
    "appId": "com.626labs.rbx15maker",
    "files": [
      "main.js",
      "editor.html",
      "editor.js",
      "styles.css",
      "lib/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "packs",
        "to": "packs",
        "filter": [
          "**/*.png"
        ]
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "@napi-rs/canvas": "^1.0.2",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0"
  }
}
